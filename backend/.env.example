# App
APP_NAME=Brolier 360 API
API_V1_PREFIX=/api/v1
PRODUCTION=False
SECRET_KEY=replace-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=90

# Database
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/brolier_360

# CORS and Host Validation
CORS_ORIGINS=["*"]
ALLOWED_HOSTS=["*"]
CORS_ALLOW_CREDENTIALS=False

# Database Pool (direct Postgres only — production uses PgBouncer + NullPool)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# RustFS Object Storage
RUSTFS_ENDPOINT_URL=http://127.0.0.1:9000
RUSTFS_ACCESS_KEY_ID=rustfsadmin
RUSTFS_SECRET_ACCESS_KEY=rustfssecret
RUSTFS_REGION_NAME=us-east-1
RUSTFS_BUCKET_NAME=brolier-360
RUSTFS_SERVER_DOMAINS=
RUSTFS_S3_HOST_HEADER=
RUSTFS_PUBLIC_BASE_URL=
# Prefer True in production once bucket/CDN allows anonymous GET (see docs/rustfs.md).
RUSTFS_PUBLIC_READ_ENABLED=False
RUSTFS_CONNECT_TIMEOUT_SECONDS=5
RUSTFS_READ_TIMEOUT_SECONDS=15

# Redis (optional — permission cache, shop hot reads, org→schema)
# Put password in URL: redis://:PASSWORD@host:6379/0
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PREFIX=brolier360
REDIS_PERMISSION_CACHE_TTL=30
REDIS_SHOP_BILLS_CACHE_TTL=10
REDIS_SHOP_BOOTSTRAP_CACHE_TTL=45
REDIS_INVENTORY_SUMMARY_CACHE_TTL=8
REDIS_ORG_SCHEMA_CACHE_TTL=300

ITEM_IMAGE_MAX_BYTES=5242880
ITEM_IMAGE_THUMBNAIL_SIZE=192
ITEM_IMAGE_FULL_MAX_SIZE=1024
